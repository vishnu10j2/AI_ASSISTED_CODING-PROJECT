<% locals.activePage = 'complaints' %>
<%- include('../partials/head') %>
<div class="app-container">
  <%- include('../partials/sidebar') %>
  <div class="main-content">
    <%- include('../partials/topbar') %>
    <div class="page-content">
      <%- include('../partials/flash') %>
      <div class="page-header">
        <div><h1>Complaint Management</h1><p>Review and respond to resident complaints</p></div>
      </div>
      <div class="card">
        <div class="table-wrapper">
          <% if (complaints.length === 0) { %>
          <div class="empty-state">
            <div class="empty-icon"><i class="fas fa-smile"></i></div>
            <h6>No complaints filed</h6>
          </div>
          <% } else { %>
          <table>
            <thead>
              <tr><th>#</th><th>Title</th><th>Category</th><th>Resident</th><th>Filed On</th><th>Status</th><th>Update</th></tr>
            </thead>
            <tbody>
              <% complaints.forEach((c, i) => { %>
              <tr>
                <td class="text-muted"><%= i+1 %></td>
                <td>
                  <div class="complaint-title"><%= c.title %></div>
                  <div class="complaint-meta"><%= c.description.substring(0, 50) %><%= c.description.length > 50 ? '…' : '' %></div>
                </td>
                <td><span class="badge" style="background:var(--body-bg);color:#4a5568;"><%= c.category %></span></td>
                <td>
                  <div class="fw-semibold"><%= c.resident ? c.resident.name : 'N/A' %></div>
                  <div class="text-muted"><%= c.resident ? c.resident.email : '' %></div>
                </td>
                <td class="text-muted"><%= new Date(c.createdAt).toLocaleDateString('en-IN') %></td>
                <td><span class="badge badge-<%= c.status.toLowerCase().replace(' ','-') %>"><%= c.status %></span></td>
                <td>
                  <form action="/admin/complaints/<%= c._id %>/update" method="POST" style="display:flex;flex-direction:column;gap:6px;min-width:190px;">
                    <select name="status" class="form-select" style="font-size:0.78rem;padding:5px 8px;">
                      <% ['Open','In Progress','Resolved'].forEach(s => { %>
                      <option value="<%= s %>" <%= c.status === s ? 'selected' : '' %>><%= s %></option>
                      <% }) %>
                    </select>
                    <input type="text" name="adminResponse" class="form-control" style="font-size:0.75rem;padding:5px 8px;" placeholder="Response..." value="<%= c.adminResponse || '' %>" />
                    <button type="submit" class="btn btn-sm btn-primary"><i class="fas fa-save"></i> Update</button>
                  </form>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
