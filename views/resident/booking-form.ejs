<% locals.activePage = 'rooms' %>
<%- include('../partials/head') %>
<div class="app-container">
  <%- include('../partials/sidebar') %>
  <div class="main-content">
    <%- include('../partials/topbar') %>
    <div class="page-content">
      <%- include('../partials/flash') %>
      <div class="page-header">
        <div><h1>Book Room <%= room.roomNumber %></h1><p>Submit your booking request for review</p></div>
        <a href="/resident/rooms" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Back</a>
      </div>

      <div style="display:grid;grid-template-columns:1fr 340px;gap:20px;align-items:start;flex-wrap:wrap;">
        <!-- Form -->
        <div class="card">
          <div class="card-header"><h5><i class="fas fa-calendar-plus" style="color:var(--accent);margin-right:8px;"></i>Booking Details</h5></div>
          <div class="card-body">
            <form action="/resident/rooms/<%= room._id %>/book" method="POST">
              <div style="margin-bottom:16px;">
                <label class="form-label">Check-In Date <span style="color:var(--danger)">*</span></label>
                <input type="date" name="checkIn" class="form-control" required
                  min="<%= new Date().toISOString().split('T')[0] %>" />
              </div>
              <div style="margin-bottom:16px;">
                <label class="form-label">Check-Out Date <span style="color:var(--danger)">*</span></label>
                <input type="date" name="checkOut" class="form-control" required
                  min="<%= new Date().toISOString().split('T')[0] %>" />
              </div>
              <div style="margin-bottom:20px;">
                <label class="form-label">Additional Note</label>
                <textarea name="note" class="form-control" rows="3" placeholder="Any special requirements or message to admin..."></textarea>
              </div>
              <div style="display:flex;gap:10px;">
                <button type="submit" class="btn btn-primary"><i class="fas fa-paper-plane"></i> Submit Request</button>
                <a href="/resident/rooms" class="btn btn-secondary">Cancel</a>
              </div>
            </form>
          </div>
        </div>

        <!-- Room Summary -->
        <div class="card">
          <div class="card-header"><h5><i class="fas fa-door-open" style="color:var(--primary-light);margin-right:8px;"></i>Room Summary</h5></div>
          <div class="card-body">
            <div style="background:linear-gradient(135deg,var(--primary),var(--primary-light));border-radius:10px;padding:16px;color:white;margin-bottom:16px;text-align:center;">
              <div style="font-size:2rem;font-weight:700;"><%= room.roomNumber %></div>
              <div style="opacity:.85;font-size:.875rem;"><%= room.type %></div>
            </div>
            <div class="info-row"><span class="info-label"><i class="fas fa-layer-group"></i> Floor</span><span class="info-value"><%= room.floor %></span></div>
            <div class="info-row"><span class="info-label"><i class="fas fa-users"></i> Capacity</span><span class="info-value"><%= room.capacity %> person<%= room.capacity > 1 ? 's' : '' %></span></div>
            <div class="info-row"><span class="info-label"><i class="fas fa-rupee-sign"></i> Price</span><span class="info-value" style="font-weight:700;color:var(--success);">₹<%= room.price.toLocaleString('en-IN') %>/mo</span></div>
            <div class="info-row" style="border:none;"><span class="info-label"><i class="fas fa-circle" style="color:var(--success);font-size:.6rem;"></i> Status</span><span class="info-value"><span class="badge badge-available">Available</span></span></div>
            <% if (room.amenities.length > 0) { %>
            <hr class="section-divider" />
            <div style="font-size:.78rem;font-weight:600;color:#718096;margin-bottom:8px;">AMENITIES</div>
            <div class="room-amenities">
              <% room.amenities.forEach(a => { %><span class="amenity-tag"><%= a %></span><% }) %>
            </div>
            <% } %>
            <% if (room.description) { %>
            <hr class="section-divider" />
            <p style="font-size:.82rem;color:#718096;margin:0;"><%= room.description %></p>
            <% } %>
          </div>
        </div>
      </div>

    </div>
  </div>
</div>
<%- include('../partials/footer') %>
