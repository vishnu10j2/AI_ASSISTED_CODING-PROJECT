<% locals.activePage = 'complaints' %>
<%- include('../partials/head') %>
<div class="app-container">
  <%- include('../partials/sidebar') %>
  <div class="main-content">
    <%- include('../partials/topbar') %>
    <div class="page-content">
      <%- include('../partials/flash') %>
      <div class="page-header">
        <div><h1>File a Complaint</h1><p>Describe your issue and we'll look into it</p></div>
        <a href="/resident/complaints" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Back</a>
      </div>
      <div class="card" style="max-width:640px;">
        <div class="card-body">
          <form action="/resident/complaints/new" method="POST">
            <div style="margin-bottom:16px;">
              <label class="form-label">Complaint Title <span style="color:var(--danger)">*</span></label>
              <input type="text" name="title" class="form-control" placeholder="Short summary of the issue" required maxlength="100" />
            </div>
            <div style="margin-bottom:16px;">
              <label class="form-label">Category</label>
              <select name="category" class="form-select">
                <% ['Maintenance','Noise','Cleanliness','Security','Other'].forEach(cat => { %>
                <option value="<%= cat %>"><%= cat %></option>
                <% }) %>
              </select>
            </div>
            <div style="margin-bottom:20px;">
              <label class="form-label">Description <span style="color:var(--danger)">*</span></label>
              <textarea name="description" class="form-control" rows="5" placeholder="Provide full details of your complaint..." required></textarea>
            </div>
            <div style="display:flex;gap:10px;">
              <button type="submit" class="btn btn-primary"><i class="fas fa-paper-plane"></i> Submit Complaint</button>
              <a href="/resident/complaints" class="btn btn-secondary">Cancel</a>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
