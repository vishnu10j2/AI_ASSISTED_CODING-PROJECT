<% locals.activePage = 'bookings' %>
<%- include('../partials/head') %>
<div class="app-container">
  <%- include('../partials/sidebar') %>
  <div class="main-content">
    <%- include('../partials/topbar') %>
    <div class="page-content">
      <%- include('../partials/flash') %>
      <div class="page-header">
        <div><h1>My Bookings</h1><p>Track all your booking requests</p></div>
        <a href="/resident/rooms" class="btn btn-primary"><i class="fas fa-plus"></i> New Booking</a>
      </div>
      <div class="card">
        <div class="table-wrapper">
          <% if (bookings.length === 0) { %>
          <div class="empty-state">
            <div class="empty-icon"><i class="fas fa-calendar-times"></i></div>
            <h6>No bookings yet</h6>
            <p>Browse available rooms and submit a booking request.</p>
            <a href="/resident/rooms" class="btn btn-primary" style="margin-top:8px;"><i class="fas fa-search"></i> Browse Rooms</a>
          </div>
          <% } else { %>
          <table>
            <thead>
              <tr><th>#</th><th>Room</th><th>Type</th><th>Check-In</th><th>Check-Out</th><th>Status</th><th>Your Note</th><th>Admin Note</th></tr>
            </thead>
            <tbody>
              <% bookings.forEach((b, i) => { %>
              <tr>
                <td class="text-muted"><%= i+1 %></td>
                <td class="fw-semibold"><%= b.room ? b.room.roomNumber : 'N/A' %></td>
                <td class="text-muted"><%= b.room ? b.room.type : '—' %></td>
                <td><%= new Date(b.checkIn).toLocaleDateString('en-IN') %></td>
                <td><%= new Date(b.checkOut).toLocaleDateString('en-IN') %></td>
                <td><span class="badge badge-<%= b.status.toLowerCase() %>"><%= b.status %></span></td>
                <td class="text-muted"><%= b.note || '—' %></td>
                <td class="text-muted"><%= b.adminNote || '—' %></td>
              </tr>
              <% }) %>
            </tbody>
          </table>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
